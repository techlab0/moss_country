# Next.js設定
NODE_ENV=development

# サイト設定
# 本番の公開URL（決済後リダイレクト・レシートURLなどの基点として使用）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 管理者認証（3つとも必須。未設定だと管理者ログインが動作しない）
# ADMIN_JWT_SECRET は `openssl rand -base64 48` などで生成したランダム値を使うこと
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=set-a-strong-unique-password
ADMIN_JWT_SECRET=generate-a-random-secret-at-least-32-characters
# USE_SUPABASE=true の場合の管理者ユーザー一覧（JSON文字列）。未使用ならコメントのままでよい
ADMIN_USERS=[]

# 多要素認証（オプション）
ADMIN_2FA_ENABLED=false
# ADMIN_2FA_ENABLED=true の場合に発行されるTOTPシークレット
ADMIN_2FA_SECRET=your-totp-secret
# カンマ区切りのバックアップコード
ADMIN_BACKUP_CODES=code1,code2,code3

# Supabase データベース設定
USE_SUPABASE=false
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Sanity CMS設定
NEXT_PUBLIC_SANITY_PROJECT_ID=z36tkqex
NEXT_PUBLIC_SANITY_DATASET=development
SANITY_API_TOKEN=your-sanity-write-token

# 決済システム設定 (Square)
SQUARE_ENVIRONMENT=sandbox
NEXT_PUBLIC_SQUARE_APPLICATION_ID=your-sandbox-app-id
SQUARE_ACCESS_TOKEN=your-sandbox-access-token
SQUARE_LOCATION_ID=your-sandbox-location-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-sandbox-location-id
# Webhook署名検証キー（Square Developer DashboardのWebhook設定画面で取得）
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
# 【POSアプリ起動決済】Developer ConsoleのPoint of Sale API欄に Web Callback URL として
# 本番の https://<ドメイン>/api/pos/callback を登録すること（コード変更は不要。登録のみ）。
# POS APIはSandbox非対応のため、動作確認は実機Square POSアプリ＋本番HTTPS＋実1円決済が必要。

# 決済システム設定 (PayPay 店頭 金額付き動的QR決済)
# PayPay for Business（開発者向けダッシュボード）で発行するAPIキー・シークレット・加盟店ID。
# PAYPAY_ENVIRONMENT は sandbox（既定）または production。未設定時はsandbox扱い。
PAYPAY_API_KEY=your-paypay-api-key
PAYPAY_API_SECRET=your-paypay-api-secret
PAYPAY_MERCHANT_ID=your-paypay-merchant-id
PAYPAY_ENVIRONMENT=sandbox

# 決済システム設定 (PayPay ECチェックアウト ウェブ決済)
# PayPay本番APIは「登録した固定IPのみ」許可のため、Vercelから直接は呼ばず、固定IPを持つ
# Xserver上の中継スクリプト（xserver-relay/paypay-relay.php。設置手順はxserver-relay/README.md）
# 経由で呼び出す。PayPayのAPIキー等はXserver側のconfig.phpにのみ置き、ここには書かない。
#
# 中継スクリプトのURL（例: https://mosscountry.com/paypay-relay/paypay-relay.php）
PAYPAY_RELAY_URL=
# 中継スクリプトのconfig.phpに設定した RELAY_SHARED_SECRET と同じ値
PAYPAY_RELAY_SECRET=
# チェックアウト画面にPayPayの支払い方法を表示するかどうか（'true' の場合のみ表示）。
# PayPay加盟店審査が未承認の間、またはPayPay決済を無効化したい場合は false のままにする/未設定にする。
# false・未設定なら、チェックアウトからPayPayの選択肢が完全に消え、既存の決済手段（クレジットカード/
# 銀行振込/代金引換）には一切影響しない（removable設計）。
NEXT_PUBLIC_PAYPAY_ENABLED=false

# メール送信設定 (Nodemailer)
# 送信基盤は環境変数で選べる。SMTP_* を設定すると汎用SMTP（AWS SES SMTP / Xserver 等）を使い、
# 未設定なら下の GMAIL_* にフォールバックする。
#
# --- 汎用SMTP（推奨: 独自ドメイン info@mosscountry.com からの送信）---
# 例(AWS SES): SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com / SMTP_PORT=587 / SMTP_SECURE=false
# 例(Xserver): SMTP_HOST=svXXXX.xserver.jp / SMTP_PORT=465 / SMTP_SECURE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# 送信元アドレス（SESの場合は検証済みドメインのアドレスにすること）
MAIL_FROM=info@mosscountry.com
# 店舗宛通知の受信先（問い合わせ・注文通知の宛先）。未設定なら既存のGmailアドレス
STORE_EMAIL=info@mosscountry.com

# --- フォールバック: Gmail SMTP ---
# 送信元GoogleアカウントでGoogleアカウントの2段階認証を有効にし、
# 「アプリパスワード」を発行してGMAIL_APP_PASSWORDに設定すること（通常のログインパスワードは使用不可）。
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Google スプレッドシート連携（オプション。サービスアカウントによる書き込み用）
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Google カレンダー連携（ワークショップ予約の空き制御用。上記と同じサービスアカウントを使用する）
# 予約管理用に使うGoogleカレンダーのカレンダーID（カレンダー設定画面の「カレンダーの統合」欄で確認できる）。
# 対象カレンダーを、上記 GOOGLE_SERVICE_ACCOUNT_EMAIL のアカウントに「予定の変更権限」で共有しておくこと。
GOOGLE_CALENDAR_ID=your-workshop-calendar-id@group.calendar.google.com

# メンテナンスモード設定
MAINTENANCE_MODE=false
# メンテナンス画面の閲覧パスワード（通常は管理画面(サイト設定 > メンテナンス)からSupabaseに保存する。
# ここに設定した値は、管理画面から一度も保存していない場合にのみ使われるフォールバック）
MAINTENANCE_PASSWORD=your-secure-maintenance-password